# Python
__pycache__/
*.pyc
*.tmp

# Cache brut régénérable (audit/reprise) : on garde le dossier et les fichiers
# « manuels » (fallback humain), mais pas les pages scrapées qui changent à
# chaque run et gonfleraient l'historique git.
data/raw/*/products_p*.json

# data/vus.json + data/nouveaux.json RESTENT versionnés = la MÉMOIRE du système
# (la routine a besoin de vus.json d'un run à l'autre ; elle committe data/).
# logs/ N'EST PLUS versionné : routine locale (plus de cron cloud), logs éphémères.

# macOS
.DS_Store

# logs runtime (éphémères, régénérés à chaque run)
logs/
